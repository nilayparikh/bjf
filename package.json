{
  "name": "braj-jan-care-static-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "check": "astro check",
    "fetch:social": "python scripts/fetch_social_media.py --output data/generated --use-existing-on-missing-credentials",
    "validate:content": "node scripts/validate-content.mjs",
    "build": "npm run check && npm run validate:content && astro build",
    "preview": "astro preview"
  },
  "dependencies": {
    "astro": "^6.1.6",
    "gray-matter": "^4.0.3",
    "tailwindcss": "^3.4.17",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "typescript": "^5.8.3"
  }
}
