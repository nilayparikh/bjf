---
interface Props {
  icon?: string;
  tone?: 'primary' | 'secondary' | 'neutral' | 'cream' | 'outline';
  class?: string;
}

const { icon, tone = 'cream', class: className } = Astro.props;

const tones = {
  primary: 'bg-primary-fixed text-on-primary-fixed',
  secondary: 'bg-secondary-fixed text-on-secondary-fixed',
  neutral: 'bg-surface-container text-on-surface',
  cream: 'bg-tertiary-fixed text-on-tertiary-fixed',
  outline: 'border border-outline-variant bg-surface-container-lowest text-on-surface-variant',
};
---

<span class:list={['inline-flex items-center gap-2 rounded-full px-3 py-1 font-label-md text-label-md', tones[tone], className]}>
  {icon && <span class="material-symbols-outlined text-[1rem]" aria-hidden="true">{icon}</span>}
  <slot />
</span>